# Origin of the FastAPI backend that the Next.js /api proxy forwards to.
#
# Server-only on purpose: it is read inside app/api/[...path]/route.ts, which
# runs on the Next.js server. Do NOT rename it to NEXT_PUBLIC_* — that would
# ship the backend origin to the browser, which must only ever talk to the
# Next.js origin (SPEC Section 24.5).
#
# Copy this file to .env.local for local development (.env.local is ignored).
BACKEND_ORIGIN=http://127.0.0.1:8000
