# Example environment configuration for the Grid Backtester V2 backend.
# Copy to `.env` and adjust locally; never commit a real `.env` file.
# All variables are optional — the defaults below suit local development.

GRID_BACKTESTER_APP_NAME=Grid Backtester V2
GRID_BACKTESTER_APP_ENVIRONMENT=development
GRID_BACKTESTER_DEBUG=false

# Local development default (SQLite file in backend/):
GRID_BACKTESTER_DATABASE_URL=sqlite:///./grid_backtester_dev.db

# PostgreSQL example (replace user/password/host/database with real values):
# GRID_BACKTESTER_DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/grid_backtester

# Authentication (HS256 JWT in an HttpOnly cookie).
# The value below is an obvious NON-SECRET placeholder for local development
# only. Production MUST set a long random secret via the environment.
GRID_BACKTESTER_AUTH_SECRET_KEY=dev-only-placeholder-not-a-real-secret
GRID_BACKTESTER_ACCESS_TOKEN_EXPIRE_MINUTES=1440
GRID_BACKTESTER_ACCESS_TOKEN_COOKIE_NAME=access_token
